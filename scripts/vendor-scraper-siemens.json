{
  "name": "siemens",
  "source_key": "siemens-developer-portal",
  "catalog_url": "https://developer.siemens.com/apis.html",
  "vendor_identity": {
    "slug": "siemens",
    "name": "Siemens",
    "summary": "Siemens industrial software, infrastructure, transportation, healthcare, and building platform APIs exposed through the Siemens developer ecosystem.",
    "sort_order": 10
  },
  "allowed_domains": [
    "developer.siemens.com",
    "docs.industrial-operations-x.siemens.cloud",
    "industrial-assets.io"
  ],
  "timeout_seconds": 30,
  "sleep_seconds": 0.0,
  "catalog_rules": {
    "entry_include_url_patterns": [
      "/overview.html",
      "/api/",
      "/home.html",
      "/index.html",
      ".html"
    ],
    "entry_exclude_url_patterns": [
      "/tags.html",
      "/guidelines/",
      "/resources/",
      "/communities/",
      "/mcps/",
      "/docs.html",
      "/index.html#",
      "mailto:",
      "x.com/",
      "linkedin.com/",
      "facebook.com/",
      "youtube.com/",
      "instagram.com/",
      "stackblitz.com/",
      "marketplace.mendix.com/",
      "github.com/"
    ],
    "entry_text_patterns": [
      " API",
      " SDK",
      "GraphQL",
      "REST",
      "OpenAPI",
      "MQTT",
      "gRPC"
    ]
  },
  "entry_rules": {
    "product_name_cleanups": [
      ["\\s+–\\s+API Overview$", ""],
      ["\\s+API Overview$", ""],
      ["^Overview$", ""]
    ],
    "api_url_preference_patterns": [
      "openapi",
      "swagger",
      "api-reference",
      "rest-api-spec",
      "api_specs",
      "protocol-documentation",
      "graphql",
      ".yaml",
      ".yml",
      ".json",
      "/api.html",
      "/external_api",
      "/apiv"
    ],
    "api_url_reject_patterns": [
      "quickstart",
      "getting-started",
      "changelog",
      "faq",
      "contact",
      "sandbox",
      "subscription",
      "run-collection",
      "postman"
    ]
  },
  "purge_rules": {
    "drop_without_spec": true,
    "drop_unusable_spec_urls": false,
    "unusable_spec_url_patterns": []
  },
  "field_mapping": {
    "path_vendor_overrides": {
      "building-x-openness": "Building X",
      "comos": "COMOS",
      "battery-passport": "Battery Passport",
